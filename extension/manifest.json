        "https://playground.anthropic.com/*",
        "https://console.anthropic.com/*",
        "https://platform.openai.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Syphir Shield"
  },
  "background": {
    "service_worker": "background.js"
  }
