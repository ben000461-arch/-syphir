{
  "manifest_version": 3,
  "name": "Syphir Shield",
  "version": "1.0.0",
  "description": "AI data protection for your business by Syphir",
  "permissions": [
    "activeTab",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://aistudio.google.com/*",
    "https://copilot.microsoft.com/*",
    "https://grok.com/*",
    "https://x.com/*",
    "https://grok.x.ai/*",
    "https://perplexity.ai/*",
    "https://www.perplexity.ai/*",
    "https://chat.mistral.ai/*",
    "https://huggingface.co/*",
    "https://poe.com/*",
    "https://character.ai/*",
    "https://www.character.ai/*",
    "https://you.com/*",
    "https://phind.com/*",
    "https://www.phind.com/*",
    "https://chat.deepseek.com/*",
    "https://groq.com/*",
    "https://playground.ai/*",
   "http://localhost:3000/*",
    "https://syphir-api.onrender.com/*",
    "https://syphir-scanner.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://grok.com/*",
        "https://x.com/*",
        "https://grok.x.ai/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://chat.mistral.ai/*",
        "https://huggingface.co/*",
        "https://poe.com/*",
        "https://character.ai/*",
        "https://www.character.ai/*",
        "https://you.com/*",
        "https://phind.com/*",
        "https://www.phind.com/*",
        "https://chat.deepseek.com/*",
        "https://groq.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Syphir Shield"
  },
  "background": {
    "service_worker": "background.js"
  }
}