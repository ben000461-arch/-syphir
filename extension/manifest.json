    "https://platform.openai.com/*",
    "https://syphir-api.onrender.com/*",
    "https://syphir-scanner.onrender.com/*",
    "http://localhost:3000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
